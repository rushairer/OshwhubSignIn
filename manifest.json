{
    "manifest_version": 3,
    "name": "OshwHub签到助手",
    "version": "1.1",
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "description": "自动检查 OshwHub 签到状态，并支持执行签到",
    "permissions": [
        "alarms",
        "notifications",
        "cookies",
        "storage",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://oshwhub.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    }
}
